; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Arcania"
config/description="A dark fantasy 2D Metroidvania — the weave is torn."
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoloads/event_bus.gd"
GameManager="*res://autoloads/game_manager.gd"
SaveManager="*res://autoloads/save_manager.gd"
AudioManager="*res://autoloads/audio_manager.gd"
SpellManager="*res://autoloads/spell_manager.gd"
InventorySystem="*res://autoloads/inventory_system.gd"
QuestManager="*res://autoloads/quest_manager.gd"
MapManager="*res://autoloads/map_manager.gd"
CombatJuice="*res://autoloads/combat_juice.gd"
InputSetup="*res://autoloads/input_setup.gd"
PlaytestTracker="*res://autoloads/playtest_tracker.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
window/stretch/scale=2.0

[gameplay]

tile_size=64
coyote_frames=6
jump_buffer_frames=8
dash_iframes=14
hit_iframes=20
target_fps=60

